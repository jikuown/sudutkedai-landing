---
// src/components/Hero.astro
---

<section class="hero" id="home">
  <div class="hero-left">
    <div class="hero-badge">Kawasan Cileungsi · Bogor</div>
    <h1 class="hero-title">
      Sudut <span class="accent">Kedai</span> ×<br />
      <span class="red">Waroeng</span><br />
      Soeroboyo
    </h1>
    <p class="hero-subtitle">Lawas & Modern, Dalam Satu Sudut</p>
    <p class="hero-desc">
      Tempat nongkrong aesthetic yang memadukan cita rasa otentik Jawa Timur
      dengan suasana kafe modern yang cozy. Live music, meeting room, dan menu
      yang bikin nagih.
    </p>
    <div class="hero-actions">
      <a href="#menu" class="btn-primary">Lihat Menu</a>
      <a href="#event" class="btn-secondary">Paket Event</a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <strong>2</strong>
        <span>Cabang Aktif</span>
      </div>
      <div class="hero-stat">
        <strong>100+</strong>
        <span>Kapasitas Acara</span>
      </div>
      <div class="hero-stat">
        <strong>50+</strong>
        <span>Pilihan Menu</span>
      </div>
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-img-wrap"></div>
    <div class="hero-float-card">
      <img src="/hero-float-kopi.jpg" alt="Kopi Beneran Sudut Kedai" class="float-img" />
      <div class="float-body">
        <div class="label">Andalan Kami</div>
        <div class="dish">Kopi Beneran</div>
        <div class="price">Rp 27.000</div>
        <div class="badge-tag">☕ Signature Drink</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    position: relative;
    overflow: hidden;
  }
  .hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px 60px 80px;
    position: relative;
    z-index: 2;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(201,151,58,0.12);
    border: 1px solid rgba(201,151,58,0.3);
    padding: 8px 18px;
    border-radius: 2px;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--gold);
    width: fit-content;
    margin-bottom: 30px;
    animation: fadeUp 0.8s ease both;
  }
  .hero-badge::before { content: '✦'; }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(42px, 5vw, 68px);
    line-height: 1.08;
    font-weight: 900;
    color: var(--cream);
    margin-bottom: 10px;
    animation: fadeUp 0.8s ease 0.1s both;
  }
  .hero-title .accent { color: var(--gold2); font-style: italic; }
  .hero-title .red    { color: var(--terra); }
  .hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 30px);
    font-style: italic;
    color: var(--muted);
    margin-bottom: 28px;
    animation: fadeUp 0.8s ease 0.2s both;
  }
  .hero-desc {
    font-size: 15px;
    line-height: 1.8;
    color: var(--cream2);
    max-width: 420px;
    margin-bottom: 44px;
    animation: fadeUp 0.8s ease 0.3s both;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    animation: fadeUp 0.8s ease 0.4s both;
  }
  .hero-stats {
    display: flex;
    gap: 40px;
    margin-top: 60px;
    padding-top: 36px;
    border-top: 1px solid rgba(255,255,255,0.08);
    animation: fadeUp 0.8s ease 0.5s both;
  }
  .hero-stat strong {
    display: block;
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--gold2);
  }
  .hero-stat span {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  .hero-right {
    position: relative;
    overflow: hidden;
  }
  .hero-img-wrap {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, var(--bg) 0%, transparent 30%),
      linear-gradient(to top, var(--bg) 0%, transparent 40%),
      url('/hero-bg.jpg') center/cover no-repeat;
    animation: zoomIn 8s ease both;
  }
  .hero-float-card {
    position: absolute;
    bottom: 80px;
    left: -30px;
    background: rgba(28,18,8,0.92);
    border: 1px solid rgba(201,151,58,0.25);
    border-radius: 8px;
    overflow: hidden;
    backdrop-filter: blur(10px);
    animation: fadeUp 1s ease 0.6s both;
    z-index: 3;
    display: flex;
    width: 260px;
  }
  .float-img {
    width: 90px;
    height: 100%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .float-body {
    padding: 14px 16px;
  }
  .hero-float-card .label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .hero-float-card .dish {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--cream);
    font-weight: 600;
    line-height: 1.3;
  }
  .hero-float-card .price {
    font-size: 18px;
    font-weight: 600;
    color: var(--gold2);
    margin-top: 4px;
  }
  .hero-float-card .badge-tag {
    display: inline-block;
    background: var(--terra);
    color: #fff;
    font-size: 10px;
    letter-spacing: 1px;
    padding: 3px 10px;
    border-radius: 2px;
    margin-top: 8px;
  }
  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-left { padding: 100px 24px 60px; }
    .hero-right { height: 320px; }
    .hero-float-card { display: none; }
    .hero-stats { gap: 24px; flex-wrap: wrap; }
  }
</style>
