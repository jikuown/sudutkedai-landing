---
// src/components/MenuCarousel.astro
// Single carousel — semua menu, foto clean di atas, nama + harga di bawah

const allMenu = [
  // ── WAROENG SOEROBOYO ──
  { img: "/menu/ayam-bakar-kecombrang.jpg", name: "Ayam Bakar Kecombrang", sub: "Waroeng Soeroboyo", price: "Rp 34.500", tag: "andalan", cat: "andalan" },
  { img: "/menu/nasi-rawon.jpg",            name: "Nasi Rawon",            sub: "Waroeng Soeroboyo", price: "Rp 39.500", tag: "hits",    cat: "andalan" },
  { img: "/menu/soto-ayam.jpg",             name: "Soto Ayam Kampung",     sub: "Waroeng Soeroboyo", price: "Rp 34.500", tag: "andalan", cat: "andalan" },
  { img: "/menu/lontong-cap-gomeh.jpg",     name: "Lontong Cap Gomeh",     sub: "Waroeng Soeroboyo", price: "Rp 39.500", tag: "hits",    cat: "makanan" },
  { img: "/menu/lontong-balap.jpg",         name: "Lontong Balap",         sub: "Waroeng Soeroboyo", price: "Rp 33.500", tag: "hits",    cat: "makanan" },
  { img: "/menu/nasi-jangan-lodeh.jpg",     name: "Nasi Jangan Lodeh",     sub: "Waroeng Soeroboyo", price: "Rp 33.500",                 cat: "makanan" },

  // ── SUDUT KEDAI — KOPI ──
  { img: "/menu/kopi-beneran.jpg",          name: "Kopi Beneran",          sub: "Sudut Kedai",       price: "Rp 27.000", tag: "signature", cat: "kopi" },
  { img: "/menu/tematik-04.jpg",            name: "Mexico Coffee",         sub: "Sudut Kedai",       price: "Rp 28.000",                   cat: "kopi" },
  { img: "/menu/tematik-05.jpg",            name: "Caramel Machiato",      sub: "Sudut Kedai",       price: "Rp 27.000",                   cat: "kopi" },
  { img: "/menu/tematik-06.jpg",            name: "Brown Sugar Latte",     sub: "Sudut Kedai",       price: "Rp 27.000", tag: "hits",       cat: "kopi" },
  { img: "/menu/tematik-07.jpg",            name: "Avocado Coffee",        sub: "Sudut Kedai",       price: "Rp 29.000",                   cat: "non-coffee" },
  { img: "/menu/tematik-08.jpg",            name: "Creamy Matcha",         sub: "Sudut Kedai",       price: "Rp 26.000",                   cat: "non-coffee" },

  // ── SUDUT KEDAI — MAKANAN ──
  { img: "/menu/nasi-goreng-gila.jpg",      name: "Nasi Goreng Gila",      sub: "Sudut Kedai",       price: "Rp 31.000", tag: "andalan", cat: "makanan" },
  { img: "/menu/nasi-goreng-original.jpg",  name: "Nasi Goreng Original",  sub: "Sudut Kedai",       price: "Rp 29.000", tag: "hits",    cat: "makanan" },
  { img: "/menu/spagheti-bolognese.jpg",    name: "Spagheti Bolognese",    sub: "Sudut Kedai",       price: "Rp 29.000",                 cat: "makanan" },
  { img: "/menu/mix-platter.jpg",           name: "Mix Platter",           sub: "Sudut Kedai",       price: "Rp 31.000", tag: "andalan", cat: "makanan" },
  { img: "/menu/tematik-14.jpg",            name: "Indomie Rebus Ngegas",  sub: "Sudut Kedai",       price: "Rp 29.000", tag: "hits",    cat: "makanan" },

  // ── CAMILAN ──
  { img: "/menu/tematik-22.jpg",            name: "French Fries",          sub: "Sudut Kedai Snack", price: "Rp 22.000", tag: "hits",    cat: "snack" },
  { img: "/menu/tematik-23.jpg",            name: "Singkong Nagih",        sub: "Sudut Kedai Snack", price: "Rp 17.000", tag: "andalan", cat: "snack" },
  { img: "/menu/tematik-24.jpg",            name: "Pisang Bakar",          sub: "Sudut Kedai Snack", price: "Rp 23.000",                 cat: "snack" },
  { img: "/menu/tematik-25.jpg",            name: "Roti Bakar",            sub: "Sudut Kedai Snack", price: "Rp 25.000",                 cat: "snack" },
