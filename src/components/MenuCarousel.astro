---

<section class="section menu-carousel-section" id="menu">
  <div class="section-label reveal">Pilihan Menu</div>
  <h2 class="section-title reveal">
    Dari Kopi Hingga<br />
    <em style="color:var(--gold)">Rawon Otentik</em>
  </h2>
  <p class="section-desc reveal" style="margin-bottom:50px">
    Geser untuk jelajahi menu kami. Dua karakter, satu tempat.
  </p>

  <!-- CATEGORY TABS -->
  <div class="menu-tabs reveal">
    {categories.map((cat, i) => (
      <button
        class={`menu-tab ${i === 0 ? 'active' : ''}`}
        data-category={cat.id}
      >
        {cat.emoji} {cat.label}
      </button>
    ))}
  </div>

  <!-- SWIPER CAROUSELS -->
  {categories.map((cat, i) => (
    <div class={`swiper menu-swiper ${i === 0 ? 'active' : ''}`} id={`swiper-${cat.id}`}>
      <div class="swiper-wrapper">
        {cat.items.map(item => (
          <div class="swiper-slide">
            <div class="menu-card">
              <div class="menu-card-img">
                <img
                  src={item.img}
                  alt={item.name}
                  onerror="this.parentElement.style.background='linear-gradient(135deg,#2a1a0c,#1a0e05)';this.style.display='none'"
                />
                {item.tag && (
                  <div class={`menu-card-tag tag-${item.tag}`}>{item.tagLabel}</div>
                )}
              </div>
              <div class="menu-card-body">
                <div class="menu-card-name">{item.name}</div>
                <div class="menu-card-sub">{item.sub}</div>
                <div class="menu-card-price">{item.price}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <!-- Pagination only -->
      <div class="swiper-pagination"></div>
    </div>
  ))}

  <!-- HINT TEXT -->
  <p class="swipe-hint reveal">← Geser atau drag untuk jelajahi →</p>
</section>

<!-- SWIPER CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
  .menu-carousel-section { background: var(--bg2); }

  /* TABS */
  .menu-tabs {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }
  .menu-tab {
    padding: 10px 24px;
    font-size: 12px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 3px;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.3s;
    font-family: var(--font-body);
  }
  .menu-tab.active {
    background: var(--terra);
    border-color: var(--terra);
    color: #fff;
  }
  .menu-tab:hover:not(.active) {
    color: var(--cream);
    border-color: rgba(255,255,255,0.2);
  }

  /* SWIPER WRAPPER */
  .menu-swiper {
    display: none;
    width: 100%;
    padding: 40px 0 70px !important;
  }
  .menu-swiper.active { display: block; }

  /* MENU CARD */
  .menu-card {
    background: var(--bg);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.3s;
    height: 100%;
  }
  .swiper-slide-active .menu-card {
    border-color: rgba(201,151,58,0.4);
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
  }
  .menu-card-img {
    width: 100%;
    height: 220px;
    overflow: hidden;
    position: relative;
    background: linear-gradient(135deg, #2a1a0c, #1a0e05);
  }
  .menu-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .swiper-slide-active .menu-card-img img {
    transform: scale(1.04);
  }
  .menu-card-tag {
    position: absolute;
    top: 12px; right: 12px;
    font-size: 10px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 2px;
    font-weight: 600;
  }
  .tag-andalan { background: var(--terra); color: #fff; }
  .tag-hits    { background: var(--gold); color: var(--bg); }
  .tag-new     { background: #3d5a3e; color: #6ab06c; }

  .menu-card-body { padding: 22px 24px 28px; }
  .menu-card-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--cream);
    margin-bottom: 6px;
    line-height: 1.3;
  }
  .menu-card-sub  { font-size: 12px; color: var(--muted); letter-spacing: 0.5px; margin-bottom: 14px; }
  .menu-card-price { font-size: 22px; font-weight: 700; color: var(--gold2); }

  .swiper-pagination-bullet {
    background: var(--muted) !important;
    opacity: 1 !important;
  }
  .swiper-pagination-bullet-active {
    background: var(--gold) !important;
    transform: scale(1.3);
  }

  /* Sembunyikan arrow navigation */
  .swiper-button-prev,
  .swiper-button-next { display: none !important; }

  .swipe-hint {
    text-align: center;
    font-size: 12px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 8px;
  }

  @media (max-width: 768px) {
    .menu-tabs { gap: 6px; }
    .menu-tab  { padding: 8px 16px; font-size: 11px; }
  }
</style>

<!-- SWIPER JS -->
<script>
  import Swiper from 'swiper';
  import { EffectCoverflow, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/effect-coverflow';
  import 'swiper/css/pagination';

  const categoryOrder = ['andalan', 'kopi', 'makanan', 'camilan'];
  const swiperInstances: Record<string, any> = {};
  let autoSwitchTimer: ReturnType<typeof setTimeout> | null = null;

  function scheduleNextCategory(catId: string) {
    if (autoSwitchTimer) clearTimeout(autoSwitchTimer);
    const totalSlides = swiperInstances[`swiper-${catId}`]?.slides?.length ?? 6;
    const totalDuration = totalSlides * 2000 + 1000;
    autoSwitchTimer = setTimeout(() => {
      const nextCat = categoryOrder[(categoryOrder.indexOf(catId) + 1) % categoryOrder.length];
      switchToCategory(nextCat);
    }, totalDuration);
  }

  function switchToCategory(catId: string) {
    if (autoSwitchTimer) { clearTimeout(autoSwitchTimer); autoSwitchTimer = null; }

    document.querySelectorAll('.menu-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.menu-swiper').forEach(s => s.classList.remove('active'));

    document.querySelector(`[data-category="${catId}"]`)?.classList.add('active');
    const targetSwiper = document.getElementById(`swiper-${catId}`);
    if (targetSwiper) {
      targetSwiper.classList.add('active');
      swiperInstances[`swiper-${catId}`]?.slideTo(0, 0);
      swiperInstances[`swiper-${catId}`]?.autoplay.start();
      swiperInstances[`swiper-${catId}`]?.update();
    }

    scheduleNextCategory(catId);
  }

  // Init semua swiper
  document.querySelectorAll('.menu-swiper').forEach((el) => {
    const id = el.id;
    swiperInstances[id] = new Swiper(`#${id}`, {
      modules: [EffectCoverflow, Pagination, Autoplay],
      effect: 'coverflow',
      grabCursor: true,
      centeredSlides: true,
      slidesPerView: 'auto',
      loop: false,
      coverflowEffect: { rotate: 30, stretch: 0, depth: 120, modifier: 1, slideShadows: true },
      pagination: { el: `#${id} .swiper-pagination`, clickable: true },
      autoplay: { delay: 2000, disableOnInteraction: false, stopOnLastSlide: true },
      breakpoints: {
        320:  { slidesPerView: 1.2 },
        640:  { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
      },
    });
  });

  // Mulai auto loop dari andalan
  scheduleNextCategory('andalan');

  // Klik tab manual → reset timer, pindah ke tab itu
  document.querySelectorAll('.menu-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = (btn as HTMLElement).dataset.category;
      if (cat) switchToCategory(cat);
    });
  });
</script>