      { img: "/menu/lontong-cap-gomeh.jpg",      name: "Lontong Cap Gomeh",         sub: "Waroeng Soeroboyo Lawas", price: "Rp 39.500", tag: "hits",    tagLabel: "Hits" },
      { img: "/menu/soto-ayam.jpg",              name: "Soto Ayam Kampung",         sub: "Waroeng Soeroboyo Lawas", price: "Rp 34.500", tag: "andalan", tagLabel: "⭐ Andalan" },
      { img: "/menu/lontong-balap.jpg",          name: "Lontong Balap",             sub: "Waroeng Soeroboyo Lawas", price: "Rp 33.500", tag: "hits",    tagLabel: "Hits" },
    ]
  },
  {
    id: "kopi",
    label: "Kopi & Minuman",
    emoji: "☕",
    items: [
      { img: "/menu/kopi-beneran.jpg",  name: "Kopi Beneran",        sub: "Signature",    price: "Rp 27.000", tag: "andalan", tagLabel: "Signature" },
      { img: "/menu/tematik-04.jpg",    name: "Mexico Coffee",        sub: "Coffee",       price: "Rp 28.000" },
      { img: "/menu/tematik-05.jpg",    name: "Caramel Machiato",     sub: "Coffee",       price: "Rp 27.000" },
      { img: "/menu/tematik-06.jpg",    name: "Brown Sugar Latte",    sub: "Coffee",       price: "Rp 27.000", tag: "hits", tagLabel: "Hits" },
      { img: "/menu/tematik-07.jpg",    name: "Avocado Coffee",       sub: "Coffee",       price: "Rp 29.000" },
