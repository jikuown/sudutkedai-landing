  img: string;
  name: string;
  sub: string;
  price: string;
  tag?: string;
  tagLabel?: string;
}

interface MenuCategory {
  id: string;
  label: string;
  emoji: string;
  items: MenuItem[];
}

const categories: MenuCategory[] = [
  {
    id: "andalan",
