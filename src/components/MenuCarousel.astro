    emoji: "🍽️",
    items: [
      { img: "/menu/nasi-goreng-gila.jpg",    name: "Nasi Goreng Gila",     sub: "Tematik Sudut Kedai", price: "Rp 31.000", tag: "andalan", tagLabel: "Andalan" },
      { img: "/menu/nasi-goreng-original.jpg",name: "Nasi Goreng Original",  sub: "Tematik Sudut Kedai", price: "Rp 29.000", tag: "hits",    tagLabel: "Hits" },
      { img: "/menu/spagheti-bolognese.jpg",  name: "Spagheti Bolognese",   sub: "Western Fusion",      price: "Rp 29.000" },
