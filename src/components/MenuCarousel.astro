---
// src/components/MenuCarousel.astro
// Single carousel — semua menu, foto clean di atas, nama + harga di bawah

const allMenu = [
  // ── WAROENG SOEROBOYO ──
  { img: "/menu/ayam-bakar-kecombrang.jpg", name: "Ayam Bakar Kecombrang", sub: "Waroeng Soeroboyo", price: "Rp 34.500", tag: "andalan" },
  { img: "/menu/nasi-rawon.jpg",            name: "Nasi Rawon",            sub: "Waroeng Soeroboyo", price: "Rp 39.500", tag: "hits" },
  { img: "/menu/soto-ayam.jpg",             name: "Soto Ayam Kampung",     sub: "Waroeng Soeroboyo", price: "Rp 34.500", tag: "andalan" },
  { img: "/menu/lontong-cap-gomeh.jpg",     name: "Lontong Cap Gomeh",     sub: "Waroeng Soeroboyo", price: "Rp 39.500", tag: "hits" },
  { img: "/menu/lontong-balap.jpg",         name: "Lontong Balap",         sub: "Waroeng Soeroboyo", price: "Rp 33.500", tag: "hits" },
  { img: "/menu/nasi-jangan-lodeh.jpg",     name: "Nasi Jangan Lodeh",     sub: "Waroeng Soeroboyo", price: "Rp 33.500" },

  // ── SUDUT KEDAI — KOPI ──
  { img: "/menu/kopi-beneran.jpg",          name: "Kopi Beneran",          sub: "Sudut Kedai",       price: "Rp 27.000", tag: "signature" },
  { img: "/menu/tematik-04.jpg",            name: "Mexico Coffee",         sub: "Sudut Kedai",       price: "Rp 28.000" },
  { img: "/menu/tematik-05.jpg",            name: "Caramel Machiato",      sub: "Sudut Kedai",       price: "Rp 27.000" },
  { img: "/menu/tematik-06.jpg",            name: "Brown Sugar Latte",     sub: "Sudut Kedai",       price: "Rp 27.000", tag: "hits" },
  { img: "/menu/tematik-07.jpg",            name: "Avocado Coffee",        sub: "Sudut Kedai",       price: "Rp 29.000" },
  { img: "/menu/tematik-08.jpg",            name: "Creamy Matcha",         sub: "Sudut Kedai",       price: "Rp 26.000" },

  // ── SUDUT KEDAI — MAKANAN ──
  { img: "/menu/nasi-goreng-gila.jpg",      name: "Nasi Goreng Gila",      sub: "Sudut Kedai",       price: "Rp 31.000", tag: "andalan" },
  { img: "/menu/nasi-goreng-original.jpg",  name: "Nasi Goreng Original",  sub: "Sudut Kedai",       price: "Rp 29.000", tag: "hits" },
  { img: "/menu/spagheti-bolognese.jpg",    name: "Spagheti Bolognese",    sub: "Sudut Kedai",       price: "Rp 29.000" },
  { img: "/menu/mix-platter.jpg",           name: "Mix Platter",           sub: "Sudut Kedai",       price: "Rp 31.000", tag: "andalan" },
  { img: "/menu/tematik-14.jpg",            name: "Indomie Rebus Ngegas",  sub: "Sudut Kedai",       price: "Rp 29.000", tag: "hits" },

  // ── CAMILAN ──
  { img: "/menu/tematik-22.jpg",            name: "French Fries",          sub: "Sudut Kedai Snack", price: "Rp 22.000", tag: "hits" },
  { img: "/menu/tematik-23.jpg",            name: "Singkong Nagih",        sub: "Sudut Kedai Snack", price: "Rp 17.000", tag: "andalan" },
  { img: "/menu/tematik-24.jpg",            name: "Pisang Bakar",          sub: "Sudut Kedai Snack", price: "Rp 23.000" },
  { img: "/menu/tematik-25.jpg",            name: "Roti Bakar",            sub: "Sudut Kedai Snack", price: "Rp 25.000" },
  { img: "/menu/tematik-26.jpg",            name: "Tempe Mendoan",         sub: "Sudut Kedai Snack", price: "Rp 19.000", tag: "hits" },
];

const tagMap: Record<string, { label: string; cls: string }> = {
  andalan:   { label: "⭐ Andalan",  cls: "tag-andalan" },
  hits:      { label: "🔥 Hits",     cls: "tag-hits" },
  signature: { label: "Signature",   cls: "tag-signature" },
};
---

<section class="section menu-section" id="menu">
  <div class="section-label reveal">Pilihan Menu</div>
  <h2 class="section-title reveal">
    Dari Kopi Hingga<br />
    <em style="color:var(--gold)">Rawon Otentik</em>
  </h2>
  <p class="section-desc reveal">Geser untuk jelajahi semua menu kami.</p>

  <div class="swiper menu-swiper reveal">
    <div class="swiper-wrapper">
      {allMenu.map(item => {
        const tagInfo = item.tag ? tagMap[item.tag] : null;
        return (
          <div class="swiper-slide">
            <div class="menu-card">
              <img
                src={item.img}
                alt={item.name}
                loading="lazy"
                onerror="this.style.display='none'"
              />
              {tagInfo && (
                <span class={`menu-tag ${tagInfo.cls}`}>{tagInfo.label}</span>
              )}
              <div class="menu-info">
                <p class="menu-sub">{item.sub}</p>
                <h3 class="menu-name">{item.name}</h3>
                <p class="menu-price">{item.price}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
    <div class="swiper-pagination"></div>
  </div>

  <p class="swipe-hint reveal">← Geser atau drag untuk jelajahi →</p>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

<style>
  .menu-section { background: var(--bg2); }

  .menu-swiper {
    width: 100%;
    padding: 24px 0 60px !important;
  }
  .swiper-slide { width: 240px; }

  /* CARD = foto full */
  .menu-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3/4;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    transition: transform 0.4s, box-shadow 0.4s;
  }
  .menu-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.6);
  }

  /* FOTO isi penuh */
  .menu-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .menu-card:hover img { transform: scale(1.06); }

  /* GLASS INFO di bawah */
  .menu-info {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 14px 16px 16px;
    background: rgba(10, 6, 3, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(201,151,58,0.2);
  }
  .menu-sub {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 3px;
  }
  .menu-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .menu-price {
    font-size: 16px;
    font-weight: 700;
    color: var(--gold2);
  }

  /* TAG pojok kiri atas */
  .menu-tag {
    position: absolute;
    top: 10px; left: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
    pointer-events: none;
    z-index: 2;
  }
  .tag-andalan   { background: var(--terra); color: #fff; }
  .tag-hits      { background: #c4732c; color: #fff; }
  .tag-signature { background: rgba(201,151,58,0.92); color: #1a0e05; font-weight: 800; }

  .swiper-button-prev,
  .swiper-button-next {
    color: var(--gold) !important;
    background: rgba(15,10,5,0.85);
    width: 44px !important;
    height: 44px !important;
    border-radius: 50%;
    border: 1px solid rgba(201,151,58,0.3);
    top: 45% !important;
  }
  .swiper-button-prev::after,
  .swiper-button-next::after { font-size: 14px !important; font-weight: 800; }
  .swiper-pagination-bullet { background: var(--muted) !important; opacity: 1 !important; }
  .swiper-pagination-bullet-active { background: var(--gold) !important; transform: scale(1.3); }

  .swipe-hint {
    text-align: center;
    font-size: 11px;
    letter-spacing: 2.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 10px;
  }

  @media (max-width: 768px) {
    .swiper-slide { width: 180px; }
    .menu-name { font-size: 13px; }
    .menu-price { font-size: 15px; }
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/navigation';
  import 'swiper/css/pagination';

  new Swiper('.menu-swiper', {
    modules: [Navigation, Pagination, Autoplay],
    slidesPerView: 'auto',
    spaceBetween: 20,
    grabCursor: true,
    loop: true,
    autoplay: {
      delay: 2800,
      disableOnInteraction: true,
      pauseOnMouseEnter: true,
    },
    navigation: {
      nextEl: '.menu-swiper .swiper-button-next',
      prevEl: '.menu-swiper .swiper-button-prev',
    },
    pagination: {
      el: '.menu-swiper .swiper-pagination',
      clickable: true,
    },
  });
</script>