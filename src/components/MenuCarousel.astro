const tagMap: Record<string, { label: string; cls: string }> = {
  andalan:   { label: "⭐ Andalan",  cls: "tag-andalan" },
  hits:      { label: "🔥 Hits",     cls: "tag-hits" },
  signature: { label: "Signature",   cls: "tag-signature" },
};
---

<section class="section menu-section" id="menu">
  <div class="section-label reveal">Pilihan Menu</div>
  <h2 class="section-title reveal">
    Dari Kopi Hingga<br />
    <em style="color:var(--gold)">Rawon Otentik</em>
  </h2>
  <p class="section-desc reveal">Geser untuk jelajahi semua menu kami.</p>

  <div class="swiper menu-swiper reveal">
    <div class="swiper-wrapper">
      {allMenu.map(item => {
        const tagInfo = item.tag ? tagMap[item.tag] : null;
        return (
          <div class="swiper-slide" data-cat={item.cat}>
            <a
              class="menu-card glightbox"
              href={item.img}
              data-gallery="menu-gallery"
            >
              <img
                src={item.img}
                alt={item.name}
                loading="lazy"
                onerror="this.style.display='none'"
              />
              {tagInfo && (
                <span class={`menu-tag ${tagInfo.cls}`}>{tagInfo.label}</span>
              )}
              <div class="menu-info">
                <p class="menu-sub">{item.sub}</p>
                <h3 class="menu-name">{item.name}</h3>
                <p class="menu-price">{item.price}</p>
              </div>
            </a>
          </div>
        );
      })}
    </div>
    <div class="swiper-pagination"></div>
  </div>

  <!-- PILL FILTERS — di bawah carousel -->
  <div class="menu-filters reveal">
    <button class="pill active" data-filter="all">Semua</button>
    <button class="pill" data-filter="andalan">⭐ Andalan</button>
    <button class="pill" data-filter="kopi">☕ Kopi</button>
    <button class="pill" data-filter="non-coffee">🧋 Non-Coffee</button>
    <button class="pill" data-filter="makanan">🍽️ Makanan</button>
    <button class="pill" data-filter="snack">🍟 Snack</button>
  </div>

  <p class="swipe-hint reveal">← Geser atau drag untuk jelajahi →</p>
</section>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox/dist/css/glightbox.min.css" />

<style>
  .menu-section { background: var(--bg2); }

  .menu-swiper {
    width: 100%;
    padding: 24px 0 60px !important;
  }
  .swiper-slide { width: 240px; }

  /* CARD = foto full */
  .menu-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3/4;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    transition: transform 0.4s, box-shadow 0.4s;
  }
  .menu-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.6);
  }

  /* FOTO isi penuh */
  .menu-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .menu-card:hover img { transform: scale(1.06); }

  /* GLASS INFO On Top */
  .menu-info {
    position: absolute;
    top: 0; left: 0; right: 0;
    padding: 14px 16px 16px;
    background: rgba(10, 6, 3, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201,151,58,0.2);
  }
  .menu-sub {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    margin-bottom: 3px;
  }
  .menu-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .menu-price {
    font-size: 16px;
    font-weight: 700;
    color: var(--gold2);
  }

  /* TAG pojok kiri atas */
  .menu-tag {
    position: absolute;
    bottom: 10px; right: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
    pointer-events: none;
    z-index: 2;
  }
  .tag-andalan   { background: var(--terra); color: #fff; }
  .tag-hits      { background: #c4732c; color: #fff; }
  .tag-signature { background: rgba(201,151,58,0.92); color: #1a0e05; font-weight: 800; }

  
  /* PILL FILTERS */
  .menu-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
    justify-content: center;
  }
  .pill {
    padding: 8px 20px;
    border-radius: 999px;
    font-size: 12px;
    letter-spacing: 1px;
    font-family: var(--font-body);
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--muted);
    cursor: pointer;
    transition: all 0.25s;
    white-space: nowrap;
  }
  .pill:hover {
    color: var(--cream);
    border-color: rgba(255,255,255,0.25);
  }
  .pill.active {
    background: var(--terra);
    border-color: var(--terra);
    color: #fff;
  }

  .swipe-hint {
    text-align: center;
    font-size: 11px;
    letter-spacing: 2.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 10px;
  }

  @media (max-width: 768px) {
    .swiper-slide { width: 180px; }
    .menu-name { font-size: 13px; }
    .menu-price { font-size: 15px; }
  }
</style>

<script>
  import Swiper from 'swiper';
  import { Pagination, Autoplay } from 'swiper/modules';
  import 'swiper/css';
  import 'swiper/css/pagination';

  new Swiper('.menu-swiper', {
    modules: [Pagination, Autoplay],
    slidesPerView: 'auto',
    spaceBetween: 20,
    grabCursor: true,
    loop: true,
    autoplay: {
      delay: 2800,
      disableOnInteraction: true,
      pauseOnMouseEnter: true,
    },
  });

  // GLIGHTBOX
  const glightboxScript = document.createElement('script');
  glightboxScript.src = 'https://cdn.jsdelivr.net/npm/glightbox/dist/js/glightbox.min.js';
  glightboxScript.onload = () => {
    (window as any).GLightbox({
      selector: '.glightbox',
      touchNavigation: true,
      loop: true,
      closeButton: true,
      slideEffect: 'slide',
      descPosition: 'none',
    });
  };
  document.head.appendChild(glightboxScript);

  // PILL FILTER
  document.querySelectorAll('.pill').forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      // Update active pill
      document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');

      // Show/hide slides
      document.querySelectorAll('.menu-swiper .swiper-slide').forEach(slide => {
        const el = slide as HTMLElement;
        if (filter === 'all' || el.dataset.cat === filter) {
          el.style.display = '';
          el.style.opacity = '1';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });
</script>